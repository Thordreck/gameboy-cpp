{
  "version": 3,
  "configurePresets": [
    {
      "name": "ninja",
      "hidden": true,
      "generator": "Ninja",
      "warnings": {
        "dev": false
      }
    },
    {
      "name": "debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON",
        "CMAKE_VERBOSE_MAKEFILE": "ON"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF",
        "CMAKE_VERBOSE_MAKEFILE": "OFF"
      }
    },
    {
      "name": "relWithDebInfo",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TESTING": "OFF",
        "CMAKE_VERBOSE_MAKEFILE": "OFF"
      }
    },
    {
      "name": "with-tracy-profiling",
      "hidden": true,
      "cacheVariables": {
        "PROFILING_BACKEND": "Tracy"
      }
    },
    {
      "name": "with-ctrack-profiling",
      "hidden": true,
      "cacheVariables": {
        "PROFILING_BACKEND": "CTrack"
      }
    },
    {
      "name": "with-no-profiling",
      "hidden": true,
      "cacheVariables": {
        "PROFILING_BACKEND": "None"
      }
    },
    {
      "name": "with-sdl-ui",
      "hidden": true,
      "cacheVariables": {
        "UI_BACKEND": "SDL"
      }
    },
    {
      "name": "with-qt-ui",
      "hidden": true,
      "cacheVariables": {
        "UI_BACKEND": "Qt"
      }
    },
    {
      "name": "with-sdl-joypad",
      "hidden": true,
      "cacheVariables": {
        "JOYPAD_BACKEND": "SDL"
      }
    },
    {
      "name": "with-qt-joypad",
      "hidden": true,
      "cacheVariables": {
        "JOYPAD_BACKEND": "Qt"
      }
    },
    {
      "name": "with-sdl",
      "hidden": true,
      "inherits": ["with-sdl-ui", "with-sdl-joypad"]
    },
    {
      "name": "with-qt",
      "hidden": true,
      "inherits": ["with-qt-ui", "with-qt-joypad"]
    },

    {
      "name": "ninja-no-profiling-sdl",
      "hidden": true,
      "inherits": ["ninja", "with-no-profiling", "with-sdl"]
    },
    {
      "name": "ninja-tracy-profiling-sdl",
      "hidden": true,
      "inherits": ["ninja", "with-tracy-profiling", "with-sdl"]
    },
    {
      "name": "ninja-ctrack-profiling-sdl",
      "hidden": true,
      "inherits": ["ninja", "with-ctrack-profiling", "with-sdl"]
    },

    {
      "name": "ninja-no-profiling-qt",
      "hidden": true,
      "inherits": ["ninja", "with-no-profiling", "with-qt"]
    },
    {
      "name": "ninja-tracy-profiling-qt",
      "hidden": true,
      "inherits": ["ninja", "with-tracy-profiling", "with-qt"]
    },
    {
      "name": "ninja-ctrack-profiling-qt",
      "hidden": true,
      "inherits": ["ninja", "with-ctrack-profiling", "with-qt"]
    },

    {
      "name": "ninja-no-profiling-sdl-release",
      "displayName": "Ninja Release (SDL)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "inherits": ["ninja-no-profiling-sdl", "release"]
    },
    {
      "name": "ninja-no-profiling-qt-release",
      "displayName": "Ninja Release (Qt)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "inherits": ["ninja-no-profiling-qt", "release"]
    },

    {
      "name": "ninja-tracy-profiling-sdl-relWithDebInfo",
      "displayName": "Ninja RelWithDebInfo (Tracy, SDL)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "inherits": ["ninja-tracy-profiling-sdl", "relWithDebInfo"]
    },
    {
      "name": "ninja-ctrack-profiling-sdl-relWithDebInfo",
      "displayName": "Ninja RelWithDebInfo (ctrack, SDL)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "inherits": ["ninja-ctrack-profiling-sdl", "relWithDebInfo"]
    },
    {
      "name": "ninja-tracy-profiling-qt-relWithDebInfo",
      "displayName": "Ninja RelWithDebInfo (Tracy, Qt)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "inherits": ["ninja-tracy-profiling-qt", "relWithDebInfo"]
    },
    {
      "name": "ninja-ctrack-profiling-qt-relWithDebInfo",
      "displayName": "Ninja RelWithDebInfo (ctrack, Qt)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "inherits": ["ninja-ctrack-profiling-qt", "relWithDebInfo"]
    },

    {
      "name": "ninja-no-profiling-sdl-debug",
      "displayName": "Ninja Debug (SDL)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "inherits": ["ninja-no-profiling-sdl", "debug"]
    },
    {
      "name": "ninja-no-profiling-qt-debug",
      "displayName": "Ninja Debug (Qt)",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "inherits": ["ninja-no-profiling-qt", "debug"]
    }
  ],
  "testPresets": [
    {
      "name": "test",
      "displayName": "Test",
      "configurePreset": "debug"
    }
  ]
}