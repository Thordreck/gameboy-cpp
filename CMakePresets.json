{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "warnings": {
        "dev": false
      }
    },
    {
      "name": "with-ccache",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER_LAUNCHER": "ccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON",
        "CMAKE_VERBOSE_MAKEFILE": "ON"
      }
    },
    {
      "name": "debug-ccache",
      "binaryDir": "${sourceDir}/build/debug-ccache",
      "displayName": "Debug (ccache)",
      "inherits": ["debug", "with-ccache"]
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF",
        "CMAKE_VERBOSE_MAKEFILE": "OFF"
      }
    },
    {
      "name": "release-ccache",
      "displayName": "Release (ccache)",
      "binaryDir": "${sourceDir}/build/release-ccache",
      "inherits": ["release", "with-ccache"]
    },
    {
      "name": "relWithDebInfo",
      "displayName": "RelWithDebInfo",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/release-deb-info",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TESTING": "OFF",
        "CMAKE_VERBOSE_MAKEFILE": "OFF"
      }
    },
    {
      "name": "relWithDebInfo-ccache",
      "displayName": "RelWithDebInfo (ccache)",
      "binaryDir": "${sourceDir}/build/release-deb-info-ccache",
      "inherits": ["relWithDebInfo", "with-ccache"]
    },
    {
      "name": "tracy",
      "displayName": "Tracy Profiling",
      "inherits": "relWithDebInfo",
      "binaryDir": "${sourceDir}/build/release-tracy",
      "cacheVariables": {
        "PROFILING_BACKEND": "Tracy"
      }
    },
    {
      "name": "tracy-ccache",
      "displayName": "Tracy Profiling (ccache)",
      "binaryDir": "${sourceDir}/build/release-tracy-ccache",
      "inherits": ["tracy", "with-ccache"]
    },
    {
      "name": "ctrack",
      "displayName": "CTrack Profiling",
      "inherits": "relWithDebInfo",
      "binaryDir": "${sourceDir}/build/release-ctrack",
      "cacheVariables": {
        "PROFILING_BACKEND": "CTrack"
      }
    },
    {
      "name": "ctrack-ccache",
      "displayName": "CTrack Profiling (ccache)",
      "binaryDir": "${sourceDir}/build/release-ctrack-ccache",
      "inherits": ["ctrack", "with-ccache"]
    }
  ],
  "testPresets": [
    {
      "name": "test",
      "displayName": "Test",
      "configurePreset": "debug"
    }
  ]
}