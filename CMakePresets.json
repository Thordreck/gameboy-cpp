{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "warnings": {
        "dev": false
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "win-64-debug",
      "displayName": "Debug",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON",
        "CMAKE_VERBOSE_MAKEFILE": "ON"
      }
    },
    {
      "name": "win-64-release",
      "displayName": "Release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF",
        "CMAKE_VERBOSE_MAKEFILE": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "win-64-debug",
      "displayName": "Debug",
      "configurePreset": "win-64-debug"
    },
    {
      "name": "win-64-release",
      "displayName": "Release",
      "configurePreset": "win-64-release"
    }
  ],
  "testPresets": [
    {
      "name": "win-64-test-all",
      "displayName": "Test All",
      "configurePreset": "win-64-debug"
    }
  ]
}